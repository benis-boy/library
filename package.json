{
  "name": "benis-boy-homepage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --host --port 5173 --open /library/",
    "gallery:admin": "python ./dev-tools/gallery_tag_admin.py",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "powershell -ExecutionPolicy Bypass -File scripts/run-storybook-tests.ps1",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.7",
    "@mui/material": "^6.4.7",
    "@panzoom/panzoom": "^4.6.2",
    "@tailwindcss/vite": "^4.0.12",
    "@upstash/redis": "^1.38.0",
    "emoji-picker-react": "^4.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@storybook/react-vite": "^10.4.1",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "http-server": "^14.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.0.12",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  }
